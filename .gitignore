# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# --- Environment / secrets ---
.env
.env.*
*.secret
*.token
*.pem
*.key
service-account*.json
client-secret*.json
google-credentials*.json
oauth-token*.json
discord-bot-token*

# --- Generated data (regenerated by hotel_sim.generate) ---
data/hotel_sim.sqlite
data/hotel_sim.sqlite-journal
data/hotel_sim.sqlite-wal
data/hotel_sim.sqlite-shm

# --- Runtime state / reports ---
# Keep markdown reports (eval summaries) but drop large JSON/JSONL state files.
reports/*.json
reports/*.jsonl
!reports/.gitkeep

# --- OS junk ---
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# --- Editor / tool noise ---
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# --- Logs ---
*.log
reports/*.pid
